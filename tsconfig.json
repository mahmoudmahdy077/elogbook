{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "apps/web" },
    { "path": "apps/mobile" }
  ],
  "exclude": ["node_modules"]
}
