{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "experimentalDecorators": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@elogbook/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@elogbook/shared/components/native": [
        "../../packages/shared/src/components/native.ts"
      ],
      "react-native": [
        "./node_modules/react-native"
      ],
      "react-native-svg": [
        "./node_modules/react-native-svg"
      ],
      "@react-native-community/blur": [
        "./node_modules/@react-native-community/blur"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/__tests__/**/*.ts",
    "**/__tests__/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}