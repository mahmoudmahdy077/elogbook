{
  "cli": {
    "version": ">= 14.0.0"
  },
  "build": {
    "production": {
      "node": "20.18.0",
      "pnpm": "9.15.0",
      "resourceClass": "large",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENABLE_SQLCIPHER": "true"
      },
      "channel": "production",
      "autoIncrement": true,
      "distribution": "store"
    },
    "preview": {
      "node": "20.18.0",
      "pnpm": "9.15.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_ENABLE_SQLCIPHER": "false"
      },
      "channel": "preview",
      "distribution": "internal",
      "autoIncrement": true
    },
    "development": {
      "node": "20.18.0",
      "pnpm": "9.15.0",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "NODE_ENV": "development",
        "EXPO_PUBLIC_ENABLE_SQLCIPHER": "false"
      },
      "channel": "development",
      "distribution": "internal",
      "developmentClient": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./android/service-account-key.json",
        "track": "production"
      }
    }
  }
}
