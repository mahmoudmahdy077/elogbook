{
  "expo": {
    "name": "E-Logbook",
    "owner": "mahmahdys-team",
    "slug": "elogbook-t5plytminvsqg3jhrtlw",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "elogbook",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elogbook.app",
      "associatedDomains": [
        "applinks:elogbook.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to attach photos to case entries",
        "NSPhotoLibraryUsageDescription": "Photo library access is used to attach images to case entries",
        "NSFaceIDUsageDescription": "FaceID is used to keep your patient data private on this device."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2F2F7"
      },
      "package": "com.elogbook.app",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "elogbook"
            },
            {
              "scheme": "https",
              "host": "elogbook.app",
              "pathPrefix": "/"
            }
          ]
        }
      ],
      "versionCode": 30
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to attach photos to case entries"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Photo library access is used to attach images to case entries"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "extraGradleProperties": [
              "org.gradle.jvmargs=-Xmx4g -XX:MaxMetaspaceSize=512m",
              "hermes.bytecode.limit=65536",
              "reactNativeArchitectures=armeabi-v7a,arm64-v8a"
            ]
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c0d8281c-0fae-4a16-b7ba-0b7a4a170bb7"
      },
      "sentryDsn": "https://example@sentry.io/0"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
